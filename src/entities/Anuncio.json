      "description": "Plano contratado"
    },
    "visualizacoes": {
      "type": "number",
      "default": 0,
      "description": "N\u00famero de visualiza\u00e7\u00f5es"
    },
    "data_expiracao": {
      "type": "string",
      "format": "date",
      "description": "Data de expira\u00e7\u00e3o do an\u00fancio"
    },
    "servicos_oferecidos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "preco": {
            "type": "number"
          },
          "duracao": {
            "type": "string"
          }
        }
      },
      "description": "Lista de servi\u00e7os oferecidos"
    },
    "em_destaque": {
      "type": "boolean",
      "default": false,
      "description": "Se o an\u00fancio est\u00e1 em destaque"
    }
  },
  "required": [
    "titulo",
    "descricao",
    "categoria",
    "profissional",
    "cidade",
    "estado"
  ]
